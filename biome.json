{
    "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
    "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
    "files": {
        "includes": [
            "**",
            "!**/dist",
            "!**/.nx",
            "!**/coverage",
            "!**/node_modules",
            "!**/*.generated.ts",
            "!_input",
            "!packages/api-kit/src/generated"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100,
        "lineEnding": "lf"
    },
    "javascript": {
        "parser": {
            "unsafeParameterDecoratorsEnabled": true
        },
        "formatter": {
            "quoteStyle": "single",
            "jsxQuoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "all",
            "arrowParentheses": "always"
        }
    },
    "json": {
        "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 4 }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "style": {
                "useImportType": "off"
            },
            "complexity": {
                "useLiteralKeys": "off",
                "noStaticOnlyClass": "off"
            },
            "correctness": {
                "noUnusedFunctionParameters": "off"
            },
            "suspicious": {
                "noExplicitAny": "off"
            }
        }
    }
}
