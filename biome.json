{
    "$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
    "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
    "files": {
        "ignore": ["**/dist/**", "**/.nx/**", "**/coverage/**", "**/node_modules/**", "**/*.generated.ts"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100,
        "lineEnding": "lf"
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "jsxQuoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "all",
            "arrowParentheses": "always"
        }
    },
    "json": {
        "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 4 }
    },
    "linter": {
        "enabled": true,
        "rules": { "recommended": true }
    }
}
