{
    "name": "design-tokens",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/design-tokens/src",
    "projectType": "library",
    "targets": {
        "generate": {
            "executor": "nx:run-commands",
            "options": {
                "command": "node tools/design-tokens/build.mjs"
            }
        },
        "build": {
            "executor": "@nx/js:tsc",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/packages/design-tokens",
                "main": "packages/design-tokens/src/index.ts",
                "tsConfig": "packages/design-tokens/tsconfig.lib.json",
                "assets": [
                    "packages/design-tokens/*.md",
                    {
                        "glob": "**/*.css",
                        "input": "packages/design-tokens/src/styles",
                        "output": "styles"
                    }
                ]
            }
        },
        "test": {
            "executor": "nx:run-commands",
            "outputs": ["{projectRoot}/coverage"],
            "options": {
                "cwd": "packages/design-tokens",
                "command": "npx vitest run --coverage"
            }
        }
    },
    "tags": ["type:kit", "scope:shared"]
}
