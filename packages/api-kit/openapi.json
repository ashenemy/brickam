  "info": {
    "title": "BuildHub API",
    "description": "API маркетплейса стройматериалов BuildHub",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "health",
      "description": ""
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "Object": {
        "type": "object",
        "properties": {}
      },
      "LocalizedTextDto": {
        "type": "object",
        "properties": {
          "hy": {
            "type": "string",
            "description": "Армянский (дефолт)"
          },
          "ru": {
            "type": "string",
            "description": "Русский"
          },
          "en": {
            "type": "string",
            "description": "Английский"
          }
        },
        "required": [
          "hy",
          "ru",
          "en"
        ]
      },
      "CreateTemplateDto": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Уникальный ключ шаблона",
            "example": "auth.otp"
          },
          "type": {
            "type": "string",
            "enum": [
              "email",
              "sms"
            ],
            "description": "Канал шаблона"
          },
          "name": {
            "type": "string",
            "description": "Человекочитаемое имя"
          },
          "subject": {
            "description": "Тема письма (для email)",
            "allOf": [
              {
                "$ref": "#/components/schemas/LocalizedTextDto"
              }
            ]
          },
          "content": {
            "description": "Тело шаблона",
            "allOf": [
              {
                "$ref": "#/components/schemas/LocalizedTextDto"
              }
            ]
          },
          "variables": {
            "description": "Белый список переменных",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "isActive": {
            "type": "boolean",
            "description": "Активен ли шаблон",
            "default": true
          }
        },
        "required": [
          "key",
          "type",
          "name",
          "content",
          "variables"
        ]
      },
      "UpdateTemplateDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "email",
              "sms"
            ]
          },
          "name": {
            "type": "string"
          },
          "subject": {
            "$ref": "#/components/schemas/LocalizedTextDto"
          },
          "content": {
            "$ref": "#/components/schemas/LocalizedTextDto"
          },
          "variables": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "isActive": {
            "type": "boolean"
          },
          "updatedBy": {
            "type": "string",
            "description": "Кто обновил"
          }
        }
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+37412345678",
            "description": "Телефон Армении (+374XXXXXXXX)"
          },
          "password": {
            "type": "string",
            "example": "secret123",
            "minLength": 8
          },
          "name": {
            "type": "string",
            "example": "Արամ"
          },
          "role": {
            "type": "string",
            "enum": [
              "buyer",
              "vendor_owner"
            ],
            "example": "buyer"
          },
          "accountType": {
            "type": "string",
            "enum": [
              "individual",
              "company"
            ]
          }
        },
        "required": [
          "phone",
          "password",
          "name",
          "role"
        ]
      },
      "VerifyOtpDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+37412345678"
          },
          "code": {
            "type": "string",
            "example": "123456",
            "description": "OTP-код"
          },
          "deviceId": {
            "type": "string",
            "description": "Идентификатор устройства"
          }
        },
        "required": [
          "phone",
          "code"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+37412345678"
          },
          "password": {
            "type": "string",
            "example": "secret123"
          },
          "deviceId": {
            "type": "string",
            "description": "Идентификатор устройства"
          }
        },
        "required": [
          "phone",
          "password"
        ]
      },
      "RefreshDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "description": "Refresh-токен"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "ForgotDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+37412345678"
          }
        },
        "required": [
          "phone"
        ]
      },
      "ResetDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+37412345678"
          },
          "code": {
            "type": "string",
            "example": "123456"
          },
          "newPassword": {
            "type": "string",
            "example": "newsecret123",
            "minLength": 8
          }
        },
        "required": [
          "phone",
          "code",
          "newPassword"
        ]
      },
      "CategoryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "parentId": {
            "type": "string"
          },
          "name": {
            "$ref": "#/components/schemas/LocalizedTextDto"
          },
          "icon": {
            "type": "string"
          },
          "order": {
            "type": "number"
          },
          "calculatorType": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "slug",
          "name",
          "order"
