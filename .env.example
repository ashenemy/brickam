# ==== BuildHub секреты (НЕ коммитить реальный .env) ====
NODE_ENV=development

# База
MONGO_URI=mongodb://localhost:27017/buildhub
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh

# SMS / OTP (если sms != mock)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# AI
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
FAL_API_KEY=

# Хранилище (S3-совместимое)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# Платежи (если payment != mock)
PAYMENT_API_KEY=
PAYMENT_MERCHANT_ID=

# Курсы (если нужен ключ)
EXCHANGE_RATES_API_KEY=

# Мониторинг
SENTRY_DSN=
