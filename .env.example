# ==== BuildHub секреты/настройки (НЕ коммитить реальный .env) ====
# Скопируйте в .env и заполните. Выбор провайдеров (sms/payment/storage) — в
# config/*.toml (providers.*); здесь — только ключи/URL.
NODE_ENV=development

# База
MONGO_URI=mongodb://localhost:27017/buildhub
REDIS_URL=redis://localhost:6379

# JWT (сгенерируйте длинные случайные строки в проде)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh

# Базовый публичный URL сайта (для sitemap.xml/robots.txt и SEO)
SITE_URL=http://localhost:4000

# Логи/масштабирование
LOG_LEVEL=info
# Включить Socket.IO Redis-adapter вне прода (1 = вкл). В проде включается сам.
WS_REDIS_ADAPTER=0

# SMS / OTP — Twilio (config providers.sms=twilio). Пусто → mock (OTP в логи).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# AI
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
FAL_API_KEY=

# Хранилище медиа (S3-совместимое). Для dev через docker-compose → MinIO:
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=buildhub
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/buildhub

# Платежи (если payment != mock)
PAYMENT_API_KEY=
PAYMENT_MERCHANT_ID=

# Курсы (если нужен ключ)
EXCHANGE_RATES_API_KEY=

# Мониторинг ошибок (Sentry/GlitchTip). DSN получите в UI GlitchTip после
# создания проекта (http://localhost:8000), затем впишите сюда:
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ==== Только для docker-compose (self-hosted GlitchTip + MinIO) ====
# GlitchTip: длинный случайный секрет + опц. внешний домен.
GLITCHTIP_SECRET_KEY=change-me-glitchtip-secret
GLITCHTIP_DOMAIN=http://localhost:8000
# Postgres под GlitchTip
POSTGRES_PASSWORD=glitchtip
# Grafana (дашборды поверх Prometheus, UI http://localhost:3001)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ==== Только для стейджинга (docker-compose.staging.yml) ====
GHCR_OWNER=buildhub
TAG=latest
