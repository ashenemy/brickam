{
    "compileOnSave": false,
    "compilerOptions": {
        "rootDir": ".",
        "sourceMap": true,
        "declaration": false,
        "moduleResolution": "node",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "importHelpers": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "target": "es2022",
        "module": "esnext",
        "lib": ["es2022", "dom"],
        "skipLibCheck": true,
        "skipDefaultLibCheck": true,
        "strict": true,
        "noImplicitOverride": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true,
        "exactOptionalPropertyTypes": true,
        "useUnknownInCatchVariables": true,
        "paths": {
            "@brickam/core-kit": ["./packages/core-kit/src/index.ts"],
            "@brickam/config-kit": ["./packages/config-kit/src/index.ts"],
            "@brickam/config-kit/browser": ["./packages/config-kit/src/browser/index.ts"],
            "@brickam/domain-kit": ["./packages/domain-kit/src/index.ts"],
            "@brickam/design-tokens": ["./packages/design-tokens/src/index.ts"],
            "@brickam/db-kit": ["./packages/db-kit/src/index.ts"],
            "@brickam/server-kit": ["./packages/server-kit/src/index.ts"],
            "@brickam/ui-kit": ["./packages/ui-kit/src/index.ts"],
            "@brickam/state-kit": ["./packages/state-kit/src/index.ts"],
            "@brickam/api-kit": ["./packages/api-kit/src/index.ts"],
            "@brickam/auth-kit": ["./packages/auth-kit/src/index.ts"],
            "@brickam/i18n-kit": ["./packages/i18n-kit/src/index.ts"],
            "@brickam/i18n-kit/browser": ["./packages/i18n-kit/src/browser/index.ts"],
            "@brickam/ai-kit": ["./packages/ai-kit/src/index.ts"],
            "@brickam/calc-kit": ["./packages/calc-kit/src/index.ts"],
            "@brickam/auth": ["./packages/feature/auth/src/index.ts"],
            "@brickam/users": ["./packages/feature/users/src/index.ts"],
            "@brickam/vendors": ["./packages/feature/vendors/src/index.ts"],
            "@brickam/vendor-members": ["./packages/feature/vendor-members/src/index.ts"],
            "@brickam/catalog": ["./packages/feature/catalog/src/index.ts"],
            "@brickam/orders": ["./packages/feature/orders/src/index.ts"],
            "@brickam/payments": ["./packages/feature/payments/src/index.ts"],
            "@brickam/wishlist": ["./packages/feature/wishlist/src/index.ts"],
            "@brickam/reviews": ["./packages/feature/reviews/src/index.ts"],
            "@brickam/chat": ["./packages/feature/chat/src/index.ts"],
            "@brickam/invoices": ["./packages/feature/invoices/src/index.ts"],
            "@brickam/calculators": ["./packages/feature/calculators/src/index.ts"],
            "@brickam/currency": ["./packages/feature/currency/src/index.ts"],
            "@brickam/loyalty": ["./packages/feature/loyalty/src/index.ts"],
            "@brickam/subscriptions": ["./packages/feature/subscriptions/src/index.ts"],
            "@brickam/templates": ["./packages/feature/templates/src/index.ts"],
            "@brickam/pages": ["./packages/feature/pages/src/index.ts"],
            "@brickam/storage": ["./packages/feature/storage/src/index.ts"],
            "@brickam/vendor-bulk": ["./packages/feature/vendor-bulk/src/index.ts"],
            "@brickam/ai-search": ["./packages/feature/ai-search/src/index.ts"],
            "@brickam/ai-assistant": ["./packages/feature/ai-assistant/src/index.ts"],
            "@brickam/notifications": ["./packages/feature/notifications/src/index.ts"],
            "@brickam/analytics": ["./packages/feature/analytics/src/index.ts"],
            "@brickam/disputes": ["./packages/feature/disputes/src/index.ts"],
