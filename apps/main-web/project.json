{
    "name": "main-web",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "prefix": "app",
    "sourceRoot": "apps/main-web/src",
    "tags": ["type:app", "scope:main"],
    "targets": {
        "build": {
            "executor": "@angular/build:application",
            "outputs": ["{options.outputPath}"],
            "defaultConfiguration": "production",
            "options": {
                "outputPath": "dist/apps/main-web",
                "browser": "apps/main-web/src/main.ts",
                "tsConfig": "apps/main-web/tsconfig.app.json",
                "inlineStyleLanguage": "scss",
                "assets": [
                    {
                        "glob": "**/*",
                        "input": "apps/main-web/public"
                    }
                ],
                "styles": [
                    "packages/design-tokens/src/styles/material-theme.scss",
                    "packages/design-tokens/src/styles/index.css",
                    "apps/main-web/src/styles.scss"
                ],
                "server": "apps/main-web/src/main.server.ts",
                "ssr": {
                    "entry": "apps/main-web/src/server.ts"
                },
                "outputMode": "server",
                "allowedCommonJsDependencies": ["socket.io-client", "engine.io-client"]
            },
            "configurations": {
                "production": {
                    "budgets": [
                        {
                            "type": "initial",
                            "maximumWarning": "1.2mb",
                            "maximumError": "1.6mb"
                        },
                        {
                            "type": "anyComponentStyle",
                            "maximumWarning": "4kb",
                            "maximumError": "8kb"
                        }
                    ],
                    "outputHashing": "all"
                },
                "development": {
                    "optimization": false,
                    "extractLicenses": false,
                    "sourceMap": true
                }
            }
        },
        "serve": {
            "continuous": true,
            "executor": "@angular/build:dev-server",
            "defaultConfiguration": "development",
            "configurations": {
                "production": {
                    "buildTarget": "main-web:build:production"
                },
                "development": {
                    "buildTarget": "main-web:build:development"
                }
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        },
        "test": {
            "executor": "@angular/build:unit-test",
            "options": {
                "watch": false
            }
        },
        "serve-static": {
            "continuous": true,
            "executor": "@nx/web:file-server",
            "options": {
                "buildTarget": "main-web:build",
                "staticFilePath": "dist/apps/main-web/browser",
                "spa": true
            }
        }
    }
}
